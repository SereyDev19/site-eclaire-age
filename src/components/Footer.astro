---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const LINKEDIN = `<svg viewBox="0 0 24 24" fill="currentColor" class="w-[22px] h-[22px]"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm7 0h4v1.8c.6-1 2-2 4-2 4 0 5 2.6 5 6v6.2h-4v-5.7c0-1.4-.03-3.3-2-3.3s-2.3 1.6-2.3 3.1V21h-4V9z"/></svg>`;
const FACEBOOK = `<svg viewBox="0 0 24 24" fill="currentColor" class="w-[22px] h-[22px]"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3V2z"/></svg>`;
---

<footer class:list={["bg-ink text-white pt-[88px] pb-10", className]}>
  <div class="max-w-[1290px] mx-auto px-10">
    <div class="grid grid-cols-1 md:grid-cols-[1.4fr_1fr_1fr_1fr] gap-12 mb-12">

      <!-- Colonne 1 : logo + description -->
      <div>
        <img src="/images/logo-white.png" alt="Éclaire Âge" class="h-[26px] brightness-0 invert mb-5" />
        <p class="text-white/70 text-[14px] leading-[1.6] mb-0">
          Psychologue pour ados &amp; parents. Accompagner l'adolescence avec plus de clarté, de calme et de lien.
        </p>
        <div class="mt-5 flex gap-2">
          <a
            href="#"
            aria-label="LinkedIn"
            class="inline-flex w-11 h-11 rounded-full bg-white/8 items-center justify-center text-white hover:bg-violet-500 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer"
          >
            <Fragment set:html={LINKEDIN} />
          </a>
          <a
            href="#"
            aria-label="Facebook"
            class="inline-flex w-11 h-11 rounded-full bg-white/8 items-center justify-center text-white hover:bg-violet-500 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer"
          >
            <Fragment set:html={FACEBOOK} />
          </a>
        </div>
      </div>

      <!-- Colonne 2 : Navigation -->
      <div>
        <h4 class="text-[13px] font-semibold tracking-[.14em] uppercase text-violet-300 mb-4">Navigation</h4>
        <nav class="flex flex-col gap-2.5">
          <a href="/" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Accueil</a>
          <a href="/a-propos" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">À propos</a>
          <a href="/contact" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Contact</a>
        </nav>
      </div>

      <!-- Colonne 3 : Contact -->
      <div>
        <h4 class="text-[13px] font-semibold tracking-[.14em] uppercase text-violet-300 mb-4">Contact</h4>
        <nav class="flex flex-col gap-2.5">
          <a href="#" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Cabinet — Blagnac (31700)</a>
          <a href="tel:+33600000000" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">06 00 00 00 00</a>
          <a href="/contact" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Prendre rendez-vous</a>
          <a href="/contact" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Appel 15 min offert</a>
        </nav>
      </div>

      <!-- Colonne 4 : Légal -->
      <div>
        <h4 class="text-[13px] font-semibold tracking-[.14em] uppercase text-violet-300 mb-4">Légal</h4>
        <nav class="flex flex-col gap-2.5">
          <a href="#" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Mentions légales</a>
          <a href="#" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">Confidentialité</a>
          <a href="#" class="text-white/70 text-[14px] leading-[1.6] hover:text-white transition-colors no-underline">CGV</a>
        </nav>
      </div>
    </div>

    <!-- Bas de footer -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-[13px] text-white/50">
      <span>© 2026 Éclaire Âge — Tous droits réservés</span>
      <span>Conçu avec soin à Blagnac.</span>
    </div>
  </div>
</footer>
