---
const CHECK = `<svg viewBox="0 0 18 16" fill="currentColor" class="w-[14px] h-[12px]"><path d="M17.47.24c.57.4.7 1.17.28 1.72L7.47 15.49c-.22.3-.56.48-.94.5a1.1 1.1 0 0 1-1-.36L.38 10.72a1.24 1.24 0 0 1 0-1.74 1.17 1.17 0 0 1 1.82 0l4.08 3.9L15.68.51c.42-.55 1.22-.67 1.8-.27z"/></svg>`;
const ARROW_R = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
const HEART = `<svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d="M12 21s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/></svg>`;

const BENEFITS_MAIN = [
  { title: "Vous vous sentez moins perdu", body: "Ce flou… commence à se clarifier. Ce qui semblait confus prend peu à peu un autre sens." },
  { title: "Vous comprenez différemment certaines réactions", body: "Certaines réactions, jusque-là incompréhensibles… commencent à prendre du sens. Et ça change tout." },
];
const BENEFITS_ALSO = [
  { title: "La pression baisse", body: "Vous ressentez moins cette urgence de réagir. Un peu de recul s'installe." },
  { title: "La relation respire autrement", body: "Elle n'est pas parfaite. Mais elle devient moins tendue… et quelque chose redevient possible." },
];
---

<section class="py-10">
  <div class="bg-[#e4d2d2] rounded-[27px] mx-3 px-[72px] py-[70px] relative overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center max-w-[1180px] mx-auto">

      <!-- Colonne gauche : texte -->
      <div class="reveal">
        <span class="kicker" style="background: white;"><span class="bar"></span> Vos bénéfices</span>
        <h2 class="font-bold text-[clamp(30px,3vw,40px)] leading-[1.12] tracking-[-0.015em] text-ink mb-3 text-balance" style="font-family: 'Poppins', sans-serif;">
          Ce qui change quand on commence <span class="title-under">à comprendre</span>
        </h2>
        <p class="text-[16.5px] leading-[1.6] text-ink-muted text-left max-w-none">
          Pas forcément tout. Mais souvent… la manière de voir.
        </p>

        <!-- Bénéfices principaux -->
        <div class="mt-[34px]">
          {BENEFITS_MAIN.map(({ title, body }) => (
            <div class="grid grid-cols-[28px_1fr] gap-3.5 py-3.5 border-b border-black/6 last:border-0">
              <div class="w-7 h-7 rounded-full bg-white text-violet-600 flex items-center justify-center shadow-[0_1px_2px_rgba(44,20,60,0.04)] flex-shrink-0">
                <Fragment set:html={CHECK} />
              </div>
              <div>
                <h4 class="font-bold text-[15.5px] leading-[1.35] text-ink mb-1" style="font-family: 'Poppins', sans-serif;">{title}</h4>
                <p class="text-[14.5px] leading-[1.5] text-ink-soft m-0">{body}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Bénéfices secondaires -->
        <div class="mt-[34px]">
          <div class="font-semibold text-[13.5px] uppercase tracking-[.14em] text-violet-600 mb-4" style="font-family: 'Poppins', sans-serif;">
            Vous pourrez également
          </div>
          {BENEFITS_ALSO.map(({ title, body }) => (
            <div class="grid grid-cols-[28px_1fr] gap-3.5 py-3.5 border-b border-black/6 last:border-0">
              <div class="w-7 h-7 rounded-full bg-white text-violet-600 flex items-center justify-center shadow-[0_1px_2px_rgba(44,20,60,0.04)] flex-shrink-0">
                <Fragment set:html={CHECK} />
              </div>
              <div>
                <h4 class="font-bold text-[15.5px] leading-[1.35] text-ink mb-1" style="font-family: 'Poppins', sans-serif;">{title}</h4>
                <p class="text-[14.5px] leading-[1.5] text-ink-soft m-0">{body}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a
            href="#rdv"
            class="inline-flex items-center gap-2.5 px-7 py-[14px] bg-violet-500 text-white rounded-[999px] font-bold text-[16px] shadow-[0_8px_20px_rgba(158,107,192,0.35)] hover:bg-violet-600 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(158,107,192,0.48)] transition-all duration-300 cursor-pointer no-underline group"
            style="font-family: 'Epilogue', sans-serif;"
          >
            En savoir plus <Fragment set:html={ARROW_R} />
          </a>
        </div>
      </div>

      <!-- Colonne droite : collage photos -->
      <div class="reveal relative" style="aspect-ratio: 1/1.05;">
        <!-- Photo 1 -->
        <div
          class="absolute top-0 left-[10%] w-[62%] rounded-[33px] bg-center bg-cover shadow-[0_28px_60px_rgba(44,20,60,0.14)] overflow-hidden hover:-rotate-[5deg] hover:-translate-y-1.5 transition-transform duration-700"
          style="aspect-ratio:4/5; transform: rotate(-3deg); background-image: url('/images/Claire%20J-22.avif');"
        ></div>
        <!-- Photo 2 -->
        <div
          class="absolute bottom-0 right-0 w-[60%] rounded-[33px] bg-center bg-cover shadow-[0_28px_60px_rgba(44,20,60,0.14)] overflow-hidden hover:rotate-[6deg] hover:-translate-y-1.5 transition-transform duration-700"
          style="aspect-ratio:4/4; transform: rotate(4deg); background-image: url('/images/maman%20et%20fille.avif');"
        ></div>
        <!-- Badge 1 -->
        <div class="absolute top-[34%] right-[-6%] bg-white rounded-[999px] px-4 py-2.5 flex items-center gap-2 font-bold text-[13px] text-violet-600 shadow-[0_12px_34px_rgba(44,20,60,0.08)] z-10 rotate-[6deg]" style="font-family: 'Epilogue', sans-serif;">
          <Fragment set:html={HEART} /> Climat apaisé
        </div>
        <!-- Badge 2 -->
        <div class="absolute bottom-[34%] left-[-4%] bg-white rounded-[999px] px-4 py-2.5 flex items-center gap-2 font-bold text-[13px] text-violet-600 shadow-[0_12px_34px_rgba(44,20,60,0.08)] z-10 -rotate-[5deg]" style="font-family: 'Epilogue', sans-serif;">
          <Fragment set:html={CHECK} /> Confiance retrouvée
        </div>
      </div>

    </div>
  </div>
</section>
