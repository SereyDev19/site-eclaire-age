---
const APPROACHES = [
  {
    n: "01",
    title: "Partir de ce que vous vivez vraiment",
    body: "Pas de théorie. Pas de modèle à appliquer. On part de vos situations. De ces moments précis où vous ne savez plus quoi penser.",
  },
  {
    n: "02",
    title: "Mettre des mots sur ce qui ne se voit pas",
    body: "Ce que vous voyez… n'est souvent qu'une partie de ce qui se joue. Je vous aide à regarder aussi ce qui se passe derrière.",
  },
  {
    n: "03",
    title: "Créer un espace pour comprendre",
    body: "Un temps pour ralentir. Prendre un peu de recul. Observer. Relier ce qui semblait confus.",
  },
  {
    n: "04",
    title: "Respecter le rythme de chacun",
    body: "Pas de précipitation. Pas d'interprétation rapide. On avance à partir de ce qui est là. Sans chercher à aller plus vite.",
  },
];

const ARROW_R = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
const USERS_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-9 h-9"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3 2.7-5 6-5s6 2 6 5"/><circle cx="17" cy="9" r="2.3"/><path d="M15 20c0-2.5 1.8-4 4-4s3 1.5 3 4"/></svg>`;
---

<section class="py-[80px] lg:py-[110px] pb-0" id="approche">
  <div class="bg-[#f6f3ef] rounded-[27px] mx-3 px-5 sm:px-10 lg:px-[72px] py-[60px] lg:py-[90px] relative overflow-hidden">
    <!-- Décor radial top-right -->
    <div class="absolute -top-20 -right-20 w-[360px] h-[360px] rounded-full pointer-events-none"
         style="background: radial-gradient(circle, #f4e6ff, transparent 70%);">
    </div>

    <!-- En-tête -->
    <div class="reveal text-center max-w-[820px] mx-auto mb-16">
      <span class="kicker"><span class="bar"></span> Pourquoi me faire confiance</span>
      <h2 class="font-bold text-[clamp(30px,3vw,40px)] leading-[1.12] tracking-[-0.015em] text-ink mb-4 text-balance" style="font-family: 'Poppins', sans-serif;">
        Comment je vous aide <span class="title-under">à y voir plus clair</span>
      </h2>
      <p class="text-[16.5px] leading-[1.6] text-ink-muted max-w-[680px] mx-auto">
        Je ne vous dis pas quoi faire. Je vous aide à voir autrement.
      </p>
    </div>

    <!-- Layout 2 colonnes -->
    <div class="grid grid-cols-1 md:grid-cols-[1.25fr_1fr] gap-10 max-w-[1180px] mx-auto">

      <!-- Gauche : 4 cartes en grille 2×2 -->
      <div class="reveal-stagger grid grid-cols-1 sm:grid-cols-2 gap-[22px] content-start">
        {APPROACHES.map(({ n, title, body }) => (
          <div class="group bg-white rounded-[27px] border border-violet-200 p-8 relative hover:-translate-y-1 hover:shadow-[0_12px_34px_rgba(44,20,60,0.08)] transition-all duration-300 overflow-hidden">
            <div class="font-bold text-[13px] tracking-[.12em] text-violet-500 mb-3" style="font-family: 'Epilogue', sans-serif;">{n}</div>
            <h3 class="font-bold text-[18px] leading-[1.3] text-ink mb-3" style="font-family: 'Poppins', sans-serif;">{title}</h3>
            <p class="text-[14.5px] leading-[1.55] text-ink-muted mb-4">{body}</p>
            <a href="#" class="inline-flex items-center gap-1.5 font-bold text-[14px] text-violet-600 group-hover:gap-2.5 transition-all duration-200 no-underline cursor-pointer" style="font-family: 'Epilogue', sans-serif;">
              En savoir plus <Fragment set:html={ARROW_R} />
            </a>
          </div>
        ))}
      </div>

      <!-- Droite : feat-card + appt-card -->
      <div class="reveal flex flex-col gap-[22px]">

        <!-- Feat card -->
        <div class="bg-violet-300 rounded-[27px] p-[13px] shadow-[0_12px_34px_rgba(44,20,60,0.08)] flex-1">
          <div class="bg-white rounded-[21px] p-7 text-center">
            <div class="w-[84px] h-[84px] rounded-full mx-auto mb-3.5 flex items-center justify-center text-violet-600"
                 style="background: radial-gradient(circle at 30% 30%, #eacbff, white 78%);">
              <Fragment set:html={USERS_ICON} />
            </div>
            <h4 class="font-bold text-[20px] leading-[1.25] text-ink" style="font-family: 'Poppins', sans-serif;">
              Vous laisser votre place
            </h4>
          </div>
          <div class="bg-white rounded-[21px] p-7 mt-3.5 text-left">
            <p class="text-[14.5px] leading-[1.6] text-ink-muted mb-4">
              Je ne suis pas là pour décider à votre place. Ni pour interpréter à votre place. Mais pour vous permettre de comprendre… et de choisir ensuite. Peu à peu, quelque chose devient plus lisible. Une réaction prend un autre sens. Une manière de voir se déplace.
            </p>
            <a href="#" class="inline-flex items-center gap-1.5 font-bold text-[14px] text-violet-600 hover:gap-2.5 transition-all duration-200 no-underline cursor-pointer" style="font-family: 'Epilogue', sans-serif;">
              En savoir plus <Fragment set:html={ARROW_R} />
            </a>
          </div>
        </div>

        <!-- Appt card — RDV -->
        <div id="rdv" class="bg-white rounded-[27px] border border-violet-300 p-[26px] text-center shadow-[0_18px_40px_rgba(158,107,192,0.22)] flex flex-col items-center gap-3.5">
          <div
            class="w-16 h-16 rounded-full bg-center bg-cover shadow-[0_0_0_3px_white,0_0_0_4px_#e8c6ff]"
            style="background-image: url('/images/Claire%20J-25.avif')"
          ></div>
          <p class="text-[14.5px] leading-[1.5] text-ink-soft m-0">
            Je vous propose un <strong>appel de 15 min offert</strong> pour déterminer si un accompagnement est approprié.
          </p>
          <a
            href="#rdv"
            class="inline-flex items-center gap-2.5 px-7 py-[14px] bg-violet-500 text-white rounded-[999px] font-bold text-[16px] shadow-[0_8px_20px_rgba(158,107,192,0.35)] hover:bg-violet-600 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(158,107,192,0.48)] transition-all duration-300 cursor-pointer no-underline group"
            style="font-family: 'Epilogue', sans-serif;"
          >
            Je prends rdv <Fragment set:html={ARROW_R} />
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
