---
const FAQS = [
  { q: "Je ne sais pas si c'est vraiment le bon moment pour consulter…", a: "Il n'y a pas toujours un « bon moment ». Parfois, c'est simplement ce moment où vous vous dites : « quelque chose a changé… mais je ne sais pas quoi ». Et ça peut déjà suffire." },
  { q: "Je ne sais pas si le comportement de mon ado est normal", a: "C'est souvent là que tout devient flou. Ce n'est pas clairement inquiétant. Mais ce n'est plus vraiment comme avant non plus. Et vous restez entre les deux… sans vraiment savoir comment l'interpréter." },
  { q: "Mon ado ne parle plus… est-ce que c'est normal ?", a: "Quand il se ferme… ou qu'il parle beaucoup moins, ça peut donner cette impression. Et en même temps — est-ce que ça veut forcément dire qu'il ne veut plus de lien ? Ou est-ce qu'il peut aussi se passer autre chose… de son côté ?" },
  { q: "J'ai peur de mal faire", a: "Cette question revient souvent. « Est-ce que j'en fais trop ? Pas assez ? » Et parfois, ce doute prend beaucoup de place. Simplement le mettre à plat… peut déjà changer quelque chose." },
  { q: "Je ne sais pas par où commencer", a: "C'est souvent comme ça que ça commence. Pas avec une demande claire. Mais avec quelque chose de flou… difficile à formuler. Et peut-être que simplement commencer à mettre des mots… c'est déjà un début." },
];
---

<section class="py-[80px] lg:py-[110px]" id="faq">
  <div class="max-w-[900px] mx-auto px-10">
    <!-- En-tête -->
    <div class="reveal text-center mb-0">
      <span class="kicker"><span class="bar"></span> FAQ</span>
      <h2 class="font-bold text-[clamp(30px,3vw,40px)] leading-[1.12] tracking-[-0.015em] text-violet-600 m-0 text-balance" style="font-family: 'Poppins', sans-serif;">
        Des questions que vous vous posez peut-être
      </h2>
    </div>

    <!-- Accordéon -->
    <div class="reveal-stagger mt-12 flex flex-col gap-3">
      {FAQS.map((f, i) => (
        <div class="faq-item bg-white border border-violet-200 rounded-[18px] overflow-hidden transition-all duration-300" data-index={i}>
          <button
            class="faq-q w-full flex items-center justify-between px-7 py-[22px] font-semibold text-[15.5px] text-ink text-left hover:text-violet-600 transition-colors duration-200 cursor-pointer"
            style="font-family: 'Poppins', sans-serif;"
            aria-expanded="false"
          >
            {f.q}
            <span class="faq-toggle w-8 h-8 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center transition-all duration-300 flex-shrink-0 ml-4">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="w-3.5 h-3.5">
                <path d="M10 4v12M4 10h12"/>
              </svg>
            </span>
          </button>
          <div class="faq-a overflow-hidden max-h-0 transition-all duration-400" style="transition: max-height .4s cubic-bezier(.22,1,.36,1), padding .3s;">
            <p class="px-7 pb-6 m-0 text-ink-muted text-[14.5px] leading-[1.65]">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll('.faq-item');
  items.forEach((item) => {
    const el = item as HTMLElement;
    const btn = el.querySelector('.faq-q') as HTMLButtonElement | null;
    const answer = el.querySelector('.faq-a') as HTMLElement | null;
    const toggle = el.querySelector('.faq-toggle') as HTMLElement | null;

    btn?.addEventListener('click', () => {
      const isOpen = el.classList.contains('open');

      // Fermer tous les autres
      items.forEach(other => {
        if (other !== item) {
          const o = other as HTMLElement;
          o.classList.remove('open');
          o.querySelector('.faq-q')?.setAttribute('aria-expanded', 'false');
          const oa = o.querySelector('.faq-a') as HTMLElement | null;
          const ot = o.querySelector('.faq-toggle') as HTMLElement | null;
          if (oa) { oa.style.maxHeight = '0'; oa.style.paddingBottom = '0'; }
          if (ot) { ot.style.transform = ''; ot.style.background = ''; ot.style.color = ''; }
          o.style.borderColor = '';
          o.style.boxShadow = '';
        }
      });

      if (!isOpen) {
        el.classList.add('open');
        btn?.setAttribute('aria-expanded', 'true');
        if (answer) answer.style.maxHeight = answer.scrollHeight + 'px';
        if (toggle) { toggle.style.transform = 'rotate(45deg)'; toggle.style.background = '#9e6bc0'; toggle.style.color = 'white'; }
        el.style.borderColor = '#b988d6';
        el.style.boxShadow = '0 4px 14px rgba(44,20,60,0.06)';
      } else {
        el.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
        if (answer) answer.style.maxHeight = '0';
        if (toggle) { toggle.style.transform = ''; toggle.style.background = ''; toggle.style.color = ''; }
        el.style.borderColor = '';
        el.style.boxShadow = '';
      }
    });
  });
</script>
