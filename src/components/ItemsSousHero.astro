---
const CARDS = [
  {
    color: "#9e6bc0",
    photo: "/images/gar%C3%A7on%20qui%20ecrit.avif",
    alt: "Garçon qui écrit",
    label: "+1 700 jeunes accompagnés",
    sub: "en individuel",
  },
  {
    color: "#ff7c5c",
    photo: "/images/ecran%20education.avif",
    alt: "Écran éducation",
    label: "Des formules d'accompagnements adaptées",
    sub: "pour tous les besoins",
  },
  {
    color: "#34c9a0",
    photo: "/images/famille.avif",
    alt: "Famille",
    label: "Accompagnement en présentiel et à distance",
    sub: "selon vos besoins",
  },
];
---

<div class="reveal-stagger max-w-[1030px] mx-auto px-3 -mt-8 relative z-10 grid grid-cols-1 md:grid-cols-3 gap-5">
  {CARDS.map(({ color, photo, alt, label, sub }) => (
    <div class="bg-white rounded-[8px] shadow-[0_6px_24px_rgba(44,20,60,0.10)] overflow-hidden">
      <!-- Bande post-it -->
      <div class="h-[10px] w-full flex-shrink-0" style={`background: ${color};`}></div>
      <!-- Photo -->
      <img src={photo} alt={alt} class="w-full h-auto block" />
      <!-- Texte -->
      <div class="px-5 pt-4 pb-5">
        <p class="font-bold text-[15.5px] text-ink leading-[1.3] m-0" style="font-family: 'Poppins', sans-serif;">{label}</p>
        <p class="text-[13px] text-ink-muted mt-1 m-0">{sub}</p>
      </div>
    </div>
  ))}
</div>
