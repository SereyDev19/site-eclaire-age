---
const CHIPS = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[22px] h-[22px]"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3 2.7-5 6-5s6 2 6 5"/><circle cx="17" cy="9" r="2.3"/><path d="M15 20c0-2.5 1.8-4 4-4s3 1.5 3 4"/></svg>`,
    label: '+1 700 jeunes accompagnés',
    sub: 'en individuel',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[22px] h-[22px]"><rect x="3" y="6" width="13" height="12" rx="2"/><path d="M16 10l5-3v10l-5-3"/></svg>`,
    label: 'Présentiel &amp; visio',
    sub: 'selon vos besoins',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[22px] h-[22px]"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>`,
    label: '+7 ans d\'expérience',
    sub: 'dans le milieu scolaire',
  },
];
---

<div class="reveal-stagger max-w-[1290px] mx-auto px-12 -mt-7 relative z-10 grid grid-cols-1 md:grid-cols-3 gap-4">
  {CHIPS.map(({ icon, label, sub }) => (
    <div class="bg-white border border-[rgba(158,107,192,0.28)] rounded-[18px] px-5 py-[18px] flex gap-3.5 items-center shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300">
      <div class="w-11 h-11 rounded-xl bg-violet-100 flex items-center justify-center text-violet-600 flex-shrink-0">
        <Fragment set:html={icon} />
      </div>
      <div class="font-semibold text-[14px] leading-[1.35] text-ink">
        <span set:html={label} />
        <br/>
        <span class="font-normal text-ink-muted text-[12px]" set:html={sub} />
      </div>
    </div>
  ))}
</div>
