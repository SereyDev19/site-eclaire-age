---
const items = [
  { text: "Des formules d'accompagnements adaptés pour tous les besoins" },
  { text: "Accompagnement en présentiel et à distance" },
  { text: "+1 700 jeunes accompagnés en individuel" }
];
---

<section class="py-16 md:py-24">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      {items.map((item) => (
        <div class="group bg-surface rounded-2xl overflow-hidden shadow-sm hover:shadow-lg border border-outline/30 hover:border-primary/20 transition-all duration-300">
          <div class="aspect-[3/2] bg-surface-alt flex items-center justify-center overflow-hidden">
            <span class="text-content-light/40 text-xs">Photo</span>
          </div>
          <div class="p-5">
            <p class="text-sm font-semibold text-content text-center leading-snug group-hover:text-primary transition-colors duration-300">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
