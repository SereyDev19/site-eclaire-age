---
import ArrowRight from '@lucide/astro/icons/arrow-right';

const articles = [
  { title: "Titre H3 secondaire", excerpt: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  { title: "Titre H3 secondaire", excerpt: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  { title: "Titre H3 secondaire", excerpt: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." }
];
---

<section class="bg-primary py-16 md:py-24 overflow-hidden relative">
  <!-- Déco subtile -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-white/5 rounded-full translate-x-1/3 translate-y-1/3"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10">
    <h2 class="text-[1.7rem] sm:text-[2rem] lg:text-[2.3rem] font-bold text-white text-center tracking-tight mb-12">
      Les dernières nouvelles
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {articles.map((a) => (
        <div class="group bg-surface rounded-2xl overflow-hidden shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <div class="aspect-[16/10] bg-surface-alt flex items-center justify-center overflow-hidden">
            <span class="text-content-light/40 text-xs">Photo</span>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-content mb-2 group-hover:text-primary transition-colors duration-300">{a.title}</h3>
            <p class="text-sm text-content-light leading-relaxed mb-3">{a.excerpt}</p>
            <a href="#" class="inline-flex items-center gap-1 text-sm text-primary font-medium hover:gap-2 transition-all duration-200 cursor-pointer">
              En savoir plus
              <ArrowRight class="w-3.5 h-3.5" />
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
