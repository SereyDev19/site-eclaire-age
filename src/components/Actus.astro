---
const ARROW_R = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[13px] h-[13px]"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;
const ARROW_R_NAV = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]"><path d="M5 12h14M13 6l6 6-6 6"/></svg>`;

const ACTUS = [
  { tag: "Kit scolaire", title: "Kit scolaire pour la rentrée", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  { tag: "Atelier", title: "Atelier : confiance en soi", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  { tag: "Ressource", title: "Guide parents d'ados", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  { tag: "Événement", title: "Groupe de parole 6e-5e", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
];
---

<section class="pt-0 pb-[160px]" id="actus">
  <div class="bg-violet-600 rounded-[27px] mx-3 px-[72px] py-[80px] relative overflow-hidden">
    <!-- Déco radiale -->
    <div class="absolute -right-[120px] -top-[120px] w-[400px] h-[400px] rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(255,255,255,0.1), transparent 60%);">
    </div>
    <div class="absolute -left-[120px] -bottom-[120px] w-[340px] h-[340px] rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(232,198,255,0.2), transparent 60%);">
    </div>

    <!-- Header carousel -->
    <div class="reveal flex items-end justify-between mb-10 relative">
      <div>
        <h2 class="font-bold text-[clamp(30px,3vw,40px)] leading-[1.12] tracking-[-0.015em] text-white text-left max-w-[560px] m-0" style="font-family: 'Poppins', sans-serif;">
          Les dernières <span class="title-under" style="--color-violet-300: rgba(232,198,255,0.45)">nouvelles</span>
        </h2>
        <p class="text-white/80 text-[15px] mt-2">Ateliers, ressources et actualités du cabinet.</p>
      </div>
      <div class="flex gap-2 flex-shrink-0">
        <button id="actus-prev" class="w-11 h-11 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/22 disabled:opacity-30 disabled:cursor-default transition-colors duration-200 cursor-pointer rotate-180" aria-label="Précédent">
          <Fragment set:html={ARROW_R_NAV} />
        </button>
        <button id="actus-next" class="w-11 h-11 rounded-full bg-white/10 text-white flex items-center justify-center hover:bg-white/22 disabled:opacity-30 disabled:cursor-default transition-colors duration-200 cursor-pointer" aria-label="Suivant">
          <Fragment set:html={ARROW_R_NAV} />
        </button>
      </div>
    </div>

    <!-- Cartes -->
    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-[22px]" id="actus-grid">
      {ACTUS.slice(0, 3).map(({ tag, title, body }) => (
        <article class="bg-white rounded-[18px] overflow-hidden text-ink hover:-translate-y-1.5 hover:shadow-[0_28px_60px_rgba(44,20,60,0.14)] transition-all duration-300 cursor-pointer">
          <div class="w-full bg-center bg-cover" style="aspect-ratio:16/10; background-image: url('/images/Claire%20J-29.jpg');"></div>
          <div class="px-[22px] pt-[22px] pb-[26px]">
            <span class="inline-block text-[11px] font-semibold tracking-[.12em] uppercase text-violet-600 bg-violet-100 px-2.5 py-1.5 rounded-[999px] mb-3">{tag}</span>
            <h3 class="font-bold text-[18px] leading-[1.3] text-ink mb-2.5" style="font-family: 'Poppins', sans-serif;">{title}</h3>
            <p class="text-[14px] leading-[1.55] text-ink-muted mb-3.5">{body}</p>
            <a href="#" class="inline-flex items-center gap-1.5 font-bold text-[13px] text-violet-600 hover:gap-2.5 transition-all duration-200 no-underline cursor-pointer" style="font-family: 'Epilogue', sans-serif;">
              Lire l'article <Fragment set:html={ARROW_R} />
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const ACTUS_DATA = [
    { tag: "Kit scolaire", title: "Kit scolaire pour la rentrée", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
    { tag: "Atelier", title: "Atelier : confiance en soi", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
    { tag: "Ressource", title: "Guide parents d'ados", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
    { tag: "Événement", title: "Groupe de parole 6e-5e", body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit." },
  ];

  const VISIBLE = 3;
  let start = 0;
  const grid = document.getElementById('actus-grid');
  const prevBtn = document.getElementById('actus-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('actus-next') as HTMLButtonElement;

  function render() {
    if (!grid) return;
    const items = ACTUS_DATA.slice(start, start + VISIBLE);
    grid.innerHTML = items.map(({ tag, title, body }) => `
      <article class="bg-white rounded-[18px] overflow-hidden text-ink hover:-translate-y-1.5 hover:shadow-[0_28px_60px_rgba(44,20,60,0.14)] transition-all duration-300 cursor-pointer">
        <div class="w-full bg-center bg-cover" style="aspect-ratio:16/10; background-image: url('/images/Claire%20J-29.jpg');"></div>
        <div class="px-[22px] pt-[22px] pb-[26px]">
          <span class="inline-block text-[11px] font-semibold tracking-[.12em] uppercase text-violet-600 bg-violet-100 px-2.5 py-1.5 rounded-[999px] mb-3">${tag}</span>
          <h3 class="font-bold text-[18px] leading-[1.3] text-ink mb-2.5" style="font-family:'Poppins',sans-serif;">${title}</h3>
          <p class="text-[14px] leading-[1.55] text-ink-muted mb-3.5">${body}</p>
          <a href="#" class="inline-flex items-center gap-1.5 font-bold text-[13px] text-violet-600 hover:gap-2.5 transition-all duration-200 no-underline cursor-pointer" style="font-family:'Epilogue',sans-serif;">
            Lire l'article
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-[13px] h-[13px]"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </article>
    `).join('');
    if (prevBtn) prevBtn.disabled = start === 0;
    if (nextBtn) nextBtn.disabled = start + VISIBLE >= ACTUS_DATA.length;
  }

  prevBtn?.addEventListener('click', () => { start = Math.max(0, start - 1); render(); });
  nextBtn?.addEventListener('click', () => { start = Math.min(ACTUS_DATA.length - VISIBLE, start + 1); render(); });
  render();
</script>
