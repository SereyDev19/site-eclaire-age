---
const stats = [
  {
    number: "+7",
    label: "7 années d'expérience dans l'accompagnement (éducation nationale, orientation, adultes en transition)"
  },
  {
    number: "+1700",
    label: "+1 700 jeunes accompagnés en individuel dans un cadre institutionnel (collèges, lycées, CIO...)"
  },
  {
    number: "+50",
    label: "+50 interventions collectives (ateliers, groupes de parole, classes entières)"
  }
];
---

<section class="py-20 md:py-28 bg-surface">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-[1.7rem] sm:text-[2rem] lg:text-[2.3rem] font-extrabold text-content tracking-tight mb-4">
        Des résultats concrets, des retours sincères
      </h2>
      <p class="text-content-light max-w-2xl mx-auto leading-relaxed">
        Plus de 1 700 jeunes accompagnés, des dizaines d'ateliers, et une pratique nourrie par le terrain — pas par les théories.<br />
        Collaboration étroite avec des CPE, infirmiers scolaires, enseignants, assistants sociaux...
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 lg:gap-12">
      {stats.map((s) => (
        <div class="text-center">
          <p class="text-[4.5rem] sm:text-[5rem] lg:text-[6.5rem] font-extrabold leading-none bg-gradient-to-br from-primary via-primary to-primary-light bg-clip-text text-transparent mb-4 tracking-tight">
            {s.number}
          </p>
          <p class="text-sm text-content-light leading-relaxed max-w-[240px] mx-auto">{s.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
