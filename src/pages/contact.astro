---
import PageLayout from '../layouts/PageLayout.astro';

const frontmatter = {
  title: 'Contact — EclaireAge',
  description: "Contactez Claire. Même si c'est encore flou. Même si vous ne savez pas exactement quoi dire.",
};
---

<PageLayout frontmatter={frontmatter}>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="relative max-w-[1290px] mx-auto px-3 mt-6 pb-0">
    <div class="bg-gradient-to-br from-violet-600 to-[#7a28b8] rounded-[27px] px-8 md:px-[72px] py-[80px] relative overflow-hidden text-center">
      <!-- Décors -->
      <div class="absolute -left-[100px] -bottom-[100px] w-[380px] h-[380px] rounded-full pointer-events-none"
           style="background: radial-gradient(circle, rgba(232,198,255,0.2), transparent 60%);"></div>
      <div class="absolute -right-[80px] -top-[80px] w-[300px] h-[300px] rounded-full pointer-events-none"
           style="background: radial-gradient(circle, rgba(255,255,255,0.07), transparent 60%);"></div>

      <div class="reveal relative max-w-[680px] mx-auto">
        <span class="kicker" style="background: rgba(255,255,255,0.12); color: rgba(232,198,255,0.95); border-color: rgba(255,255,255,0.15);">
          <span class="bar" style="background: #e8c6ff;"></span> Contact
        </span>
        <h1 class="font-bold text-[clamp(32px,3.8vw,52px)] leading-[1.08] tracking-[-0.02em] text-white mb-4 text-balance" style="font-family: 'Poppins', sans-serif;">
          Vous pouvez me contacter ici
        </h1>
        <p class="text-white/75 text-[17px] leading-[1.6]">
          Même si c'est encore flou.<br />
          Même si vous ne savez pas exactement quoi dire.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT PRINCIPAL ══════════════════════════════════════ -->
  <section class="py-[100px] max-w-[1290px] mx-auto px-3">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 max-w-[1100px] mx-auto items-start">

      <!-- Colonne gauche : intro + formulaire -->
      <div class="reveal">

        <!-- Intro texte -->
        <div class="mb-10">
          <span class="kicker"><span class="bar"></span> Écrivez-moi</span>
          <h2 class="font-bold text-[clamp(24px,2.4vw,32px)] leading-[1.15] tracking-[-0.015em] text-ink mb-5" style="font-family: 'Poppins', sans-serif;">
            Quelques mots <span class="title-under">suffisent</span>
          </h2>
          <div class="flex flex-col gap-3 text-[15.5px] leading-[1.7] text-ink-soft mb-6">
            <p class="m-0">
              Parfois, il n'y a pas de «&nbsp;bonne raison&nbsp;». Juste une sensation :
            </p>
            <ul class="list-none p-0 m-0 flex flex-col gap-1.5">
              <li class="flex items-start gap-2.5">
                <span class="text-violet-500 font-bold flex-shrink-0">→</span>
                quelque chose ne va pas comme avant
              </li>
              <li class="flex items-start gap-2.5">
                <span class="text-violet-500 font-bold flex-shrink-0">→</span>
                «&nbsp;je ne sais pas si je dois m'inquiéter&nbsp;»
              </li>
            </ul>
            <p class="m-0 font-medium text-ink">Vous pouvez partir de là.</p>
          </div>
          <p class="text-[14.5px] text-ink-muted leading-[1.6]">
            Vous pouvez simplement me dire : ce que vous observez, ce qui vous questionne, ou ce qui vous inquiète.
          </p>
        </div>

        <!-- Formulaire -->
        <form class="flex flex-col gap-5" action="#" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="flex flex-col gap-1.5">
              <label class="text-[13px] font-semibold text-ink uppercase tracking-[.08em]" style="font-family: 'Epilogue', sans-serif;">
                Prénom
              </label>
              <input
                type="text"
                name="prenom"
                placeholder="Votre prénom"
                class="w-full px-4 py-3.5 rounded-[12px] border border-violet-200 bg-white text-[15px] text-ink placeholder:text-ink-muted/60 focus:outline-none focus:border-violet-400 focus:ring-2 focus:ring-violet-200 transition-all duration-200"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[13px] font-semibold text-ink uppercase tracking-[.08em]" style="font-family: 'Epilogue', sans-serif;">
                Email
              </label>
              <input
                type="email"
                name="email"
                placeholder="votre@email.com"
                class="w-full px-4 py-3.5 rounded-[12px] border border-violet-200 bg-white text-[15px] text-ink placeholder:text-ink-muted/60 focus:outline-none focus:border-violet-400 focus:ring-2 focus:ring-violet-200 transition-all duration-200"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[13px] font-semibold text-ink uppercase tracking-[.08em]" style="font-family: 'Epilogue', sans-serif;">
              Ce que vous vivez
            </label>
            <textarea
              name="message"
              rows="6"
              placeholder="Ce que vous observez, ce qui vous questionne, ou ce qui vous inquiète… Quelques mots suffisent."
              class="w-full px-4 py-3.5 rounded-[12px] border border-violet-200 bg-white text-[15px] text-ink placeholder:text-ink-muted/60 focus:outline-none focus:border-violet-400 focus:ring-2 focus:ring-violet-200 transition-all duration-200 resize-none leading-[1.6]"
            ></textarea>
          </div>

          <button
            type="submit"
            class="self-start inline-flex items-center gap-2.5 px-7 py-[14px] bg-violet-500 text-white rounded-[999px] font-bold text-[16px] shadow-[0_8px_20px_rgba(158,107,192,0.35)] hover:bg-violet-600 hover:-translate-y-0.5 hover:shadow-[0_14px_30px_rgba(158,107,192,0.48)] transition-all duration-300 cursor-pointer"
            style="font-family: 'Epilogue', sans-serif;"
          >
            Envoyer mon message
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>
        </form>
      </div>

      <!-- Colonne droite : infos + photo -->
      <div class="reveal flex flex-col gap-6">

        <!-- Card Claire -->
        <div class="bg-[#faf7f2] rounded-[20px] p-7 flex gap-5 items-start">
          <div class="relative flex-shrink-0" style="width: 64px; height: 64px;">
            <div class="absolute rounded-full animate-spin-border"
                 style="inset: -3px; background: conic-gradient(from 0deg, #9e6bc0, #e8c6ff, #ff9477, #ffd4c8, #e8c6ff, #9e6bc0);"></div>
            <div class="absolute rounded-full bg-center bg-cover"
                 style="inset: 3px; background-image: url('/images/Claire%20J-25.avif');"></div>
          </div>
          <div>
            <p class="font-bold text-[15px] text-ink m-0" style="font-family: 'Poppins', sans-serif;">Claire</p>
            <p class="text-[13px] text-violet-600 font-semibold m-0 mb-2">Psychologue — Blagnac &amp; visio</p>
            <p class="text-[14px] text-ink-muted leading-[1.55] m-0">
              Je réponds personnellement à chaque message, dans les meilleurs délais.
            </p>
          </div>
        </div>

        <!-- Appel offert -->
        <div class="bg-white rounded-[20px] border border-violet-200 p-7 shadow-[0_4px_20px_rgba(158,107,192,0.08)]">
          <div class="text-[11px] font-bold tracking-[.14em] uppercase text-violet-500 mb-3" style="font-family: 'Epilogue', sans-serif;">
            Appel découverte
          </div>
          <h3 class="font-bold text-[18px] text-ink mb-2" style="font-family: 'Poppins', sans-serif;">
            15 min offertes
          </h3>
          <p class="text-[14.5px] text-ink-muted leading-[1.6] m-0 mb-4">
            Avant de commencer, je vous propose un appel de 15 minutes — gratuit, sans engagement — pour voir si nous sommes bien alignés.
          </p>
          <a
            href="tel:+33000000000"
            class="inline-flex items-center gap-2 text-[14px] font-bold text-violet-600 hover:text-violet-700 transition-colors cursor-pointer no-underline"
            style="font-family: 'Epilogue', sans-serif;"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 10.5 19.79 19.79 0 0 1 1.61 1.87 2 2 0 0 1 3.59 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.91a16 16 0 0 0 6.18 6.18l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Me contacter par téléphone
          </a>
        </div>

        <!-- Cabinet -->
        <div class="bg-white rounded-[20px] border border-violet-200 p-7 shadow-[0_4px_20px_rgba(158,107,192,0.08)]">
          <div class="text-[11px] font-bold tracking-[.14em] uppercase text-violet-500 mb-3" style="font-family: 'Epilogue', sans-serif;">
            Où me trouver
          </div>
          <ul class="list-none p-0 m-0 flex flex-col gap-3">
            <li class="flex items-start gap-3 text-[14px] text-ink-soft leading-[1.5]">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0 mt-0.5 text-violet-500"><path d="M12 2a7 7 0 0 0-7 7c0 4.5 7 13 7 13s7-8.5 7-13a7 7 0 0 0-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
              Cabinet à <strong class="text-ink">Blagnac (31700)</strong> — proche tramway T1
            </li>
            <li class="flex items-start gap-3 text-[14px] text-ink-soft leading-[1.5]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 flex-shrink-0 mt-0.5 text-violet-500"><rect x="3" y="5" width="18" height="11" rx="1.5"/><path d="M2 19h20"/></svg>
              Séances en visio également disponibles
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ CLÔTURE ════════════════════════════════════════════════ -->
  <section class="pb-[100px] max-w-[1290px] mx-auto px-3">
    <div class="bg-[#f6f3ef] rounded-[27px] py-[60px] px-[72px] text-center">
      <p class="text-[18px] leading-[1.7] text-ink-muted italic max-w-[520px] mx-auto">
        Parfois, mettre des mots une première fois…<br />
        <em class="not-italic font-semibold text-violet-600">change déjà quelque chose.</em>
      </p>
    </div>
  </section>

</PageLayout>
