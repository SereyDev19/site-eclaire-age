---
import PageLayout from '../layouts/PageLayout.astro';
import HeroMaquette from '../components/HeroMaquette.astro';
import ItemsSousHero from '../components/ItemsSousHero.astro';
import Problematiques from '../components/Problematiques.astro';
import Accompagnement from '../components/Accompagnement.astro';
import VosBenefices from '../components/VosBenefices.astro';
import Stats from '../components/Stats.astro';
import Local from '../components/Local.astro';
import Actus from '../components/Actus.astro';
import FAQ from '../components/FAQ.astro';
import CTAFinal from '../components/CTAFinal.astro';

const frontmatter = {
  title: 'EclaireAge — Psychologue en ligne pour ados & familles',
  description: "Accompagnement psychologique sur-mesure pour adolescents et parents, en cabinet ou en visio.",
};
---

<PageLayout frontmatter={frontmatter}>
  <HeroMaquette />
  <ItemsSousHero />
  <Problematiques />
  <Accompagnement />
  <VosBenefices />
  <Stats />
  <Local />
  <Actus />
  <FAQ />
  <CTAFinal />
</PageLayout>
